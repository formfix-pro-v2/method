# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Lemon Squeezy Configuration (payment provider)
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_GLOW_VARIANT_ID=your-glow-variant-id
LEMONSQUEEZY_ELITE_VARIANT_ID=your-elite-variant-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_EMAILS=your-email@example.com
NEXT_PUBLIC_ADMIN_KEY=your-secret-admin-key

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# Cron jobs (optional)
CRON_SECRET=your-cron-secret

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# Email (optional — for future Resend integration)
RESEND_API_KEY=re_your-api-key
